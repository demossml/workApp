{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "tasks": {
      "build": {
        "dependsOn": ["^build"],
        "inputs": ["src/*", ".env*"],
        "outputs": ["dist/**"]
      },
      "lint": {
        "dependsOn": ["^lint"]
      },
      "dev": {
        "passThroughEnv": ["*"],
        "cache": false,
        "persistent": true
      },
      "deploy": {
        "passThroughEnv": ["*"],
        "dependsOn": ["build"],
        "cache": false
      }
    }
  }