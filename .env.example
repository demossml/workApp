# === Evo App Environment Variables ===

# Server port (default: 8787)
PORT=8787

# Telegram Bot Token (for WebApp auth signature verification)
BOT_TOKEN=

# Evotor API Token (X-Authorization header)
EVOTOR_API_TOKEN=

# Anthropic API Key (for AI Director)
ANTHROPIC_API_KEY=

# DeepSeek API Key (for AI Director briefing)
DEEPSEEK_API_KEY=sk-...

# DuckDB paths
DUCKDB_PATH=/home/admingimolost/.hermes/data/evotor.duckdb
DUCKDB_SETTINGS_PATH=/home/admingimolost/.hermes/data/evotor-settings.duckdb

# Vite dev server: where to proxy /api (only used in dev mode)
VITE_API_URL=http://localhost:8787
