{
	"name": "@work-appt/backend",
	"version": "1.0.0",
	"private": true,
	"main": "src/index.ts",
	"scripts": {
		"build": "tsc --noEmit",
		"test:index": "node -r esbuild-register --test src/index.scheduled.test.cjs",
		"test:shift-summary": "node -r esbuild-register --test src/services/shiftSummary.test.cjs",
		"test:tempo-alerts": "node -r esbuild-register --test src/telegram/tempoAlerts.test.cjs",
		"test:dead-stocks": "node -r esbuild-register --test src/ai/deadStocksNarrative.test.cjs utils/formatDeadStocksMessage.test.cjs",
		"test:kpi-narrative": "node -r esbuild-register --test src/ai/employeeKpiNarrative.test.cjs",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"deploy": "wrangler deploy",
		"deploy:debug": "WRANGLER_LOG=debug wrangler deploy",
		"deploy:dry-run": "WRANGLER_LOG=debug wrangler deploy --dry-run",
		"whoami": "wrangler whoami",
		"db:generate": "drizzle-kit generate",
		"db:apply-local": "wrangler d1 migrations apply DB --local",
		"db:apply-remote": "wrangler d1 migrations apply DB --remote",
		"db:seed-local": "wrangler d1 execute DB --local --file ./scripts/seed-local.sql",
		"db:prepare-local": "pnpm db:apply-local && pnpm db:seed-local"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250628.0",
		"@types/react-datepicker": "^7.0.0",
		"@types/unzip-stream": "^0.3.4",
		"drizzle-kit": "^0.31.8",
		"dts-gen": "^0.10.4",
		"hono": "^4.6.20",
		"prettier": "^3.3.3",
		"typescript": "^5.5.2",
		"wrangler": "^4.76.0"
	},
	"dependencies": {
		"@cloudflare/ai": "^1.2.2",
		"drizzle-orm": "^0.45.1",
		"jsonwebtoken": "^9.0.2",
		"jszip": "^3.10.1",
		"unbound-fetch": "^1.0.8",
		"unzip-stream": "^0.3.4",
		"workers-ai-provider": "^0.5.2",
		"zod": "^3.25.30",
		"zod-to-json-schema": "^3.24.5"
	}
}
